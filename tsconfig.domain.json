{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/domains/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/app/**/*",
    "src/lib/**/*",
    "src/components/**/*",
    "src/ctx/**/*",
    "src/hooks/**/*",
    "src/types/**/*",
    "tests/**/*"
  ]
}